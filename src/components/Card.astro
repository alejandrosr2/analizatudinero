---
interface Props {
  title: string;
  description: string;
  href?: string;
  /** Texto del enlace inferior, p. ej. "Usar calculadora". */
  linkLabel?: string;
  /** Etiqueta pequeña superior, p. ej. "Calculadora" o "Próximamente". */
  badge?: string;
  /** Nombre del icono decorativo. */
  icon?: 'calculator' | 'template' | 'guide' | 'chart' | 'home' | 'wallet';
}

const { title, description, href, linkLabel, badge, icon } = Astro.props;

const iconPaths: Record<string, string> = {
  calculator:
    'M9 7h6m-6 4h6m-6 4h2m-5 5h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z',
  template:
    'M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z',
  guide:
    'M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253',
  chart:
    'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
  home: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6',
  wallet:
    'M21 12a2.25 2.25 0 00-2.25-2.25H15a3 3 0 11-6 0H5.25A2.25 2.25 0 003 12m18 0v6a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 18v-6m18 0V9M3 12V9m18 0a2.25 2.25 0 00-2.25-2.25H5.25A2.25 2.25 0 003 9m18 0V6a2.25 2.25 0 00-2.25-2.25H5.25A2.25 2.25 0 003 6v3',
};
---

<article
  class="group relative flex h-full flex-col rounded-2xl border border-slate-200 bg-white p-6 transition-shadow hover:shadow-md"
>
  <div class="flex items-start justify-between gap-3">
    {
      icon && (
        <div class="rounded-xl bg-navy-50 p-2.5 text-navy-700">
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d={iconPaths[icon]} />
          </svg>
        </div>
      )
    }
    {
      badge && (
        <span class="rounded-full bg-mint-100 px-3 py-1 text-xs font-semibold text-mint-800">{badge}</span>
      )
    }
  </div>
  <h3 class="mt-4 text-lg font-bold text-navy-900">
    {
      href ? (
        <a href={href} class="after:absolute after:inset-0 group-hover:text-navy-700">
          {title}
        </a>
      ) : (
        title
      )
    }
  </h3>
  <p class="mt-2 flex-1 text-sm leading-relaxed text-slate-600">{description}</p>
  {
    href && linkLabel && (
      <p class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-navy-700 group-hover:text-navy-900">
        {linkLabel}
        <svg class="h-4 w-4 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </p>
    )
  }
</article>
