---
/**
 * Preview visual de la plantilla gratuita "Controla tu dinero en 30 días".
 * HTML/CSS con pestañas simuladas y datos de ejemplo hipotéticos. El archivo
 * descargable es un Excel editable con estos mismos módulos.
 */
const tabs = [
  { id: 'dashboard', label: 'Dashboard' },
  { id: 'gastos', label: 'Gastos' },
  { id: 'presupuesto', label: 'Presupuesto' },
  { id: 'objetivos', label: 'Objetivos' },
  { id: 'mudanza', label: 'Mudanza' },
  { id: 'alquiler', label: 'Alquiler' },
] as const;

const presupuesto = [
  { cat: 'Vivienda', previsto: '500 €', real: '450 €', dif: '+50 €', estado: 'Bien' },
  { cat: 'Alimentación', previsto: '250 €', real: '268 €', dif: '−18 €', estado: 'Vigilar' },
  { cat: 'Transporte', previsto: '80 €', real: '60 €', dif: '+20 €', estado: 'Bien' },
  { cat: 'Suministros', previsto: '100 €', real: '83 €', dif: '+17 €', estado: 'Bien' },
  { cat: 'Ocio', previsto: '120 €', real: '95 €', dif: '+25 €', estado: 'Bien' },
] as const;

const objetivos = [
  { nombre: 'Fondo de emergencia', objetivo: '3.000 €', ahorrado: '900 €', pct: 'w-[30%]' },
  { nombre: 'Mudanza', objetivo: '2.000 €', ahorrado: '600 €', pct: 'w-[30%]' },
  { nombre: 'Formación', objetivo: '800 €', ahorrado: '150 €', pct: 'w-[19%]' },
  { nombre: 'Vacaciones', objetivo: '700 €', ahorrado: '220 €', pct: 'w-[31%]' },
] as const;

const gastos = [
  { fecha: '03/04', cat: 'Alimentación', desc: 'Compra semanal', imp: '52,30 €' },
  { fecha: '05/04', cat: 'Transporte', desc: 'Abono mensual', imp: '40,00 €' },
  { fecha: '08/04', cat: 'Ocio', desc: 'Cena con amigos', imp: '24,50 €' },
  { fecha: '12/04', cat: 'Suministros', desc: 'Factura de la luz', imp: '43,00 €' },
  { fecha: '15/04', cat: 'Vivienda', desc: 'Alquiler', imp: '450,00 €' },
] as const;

const mudanza = [
  { concepto: 'Fianza', imp: '700 €' },
  { concepto: 'Primer mes de alquiler', imp: '700 €' },
  { concepto: 'Transporte y portes', imp: '150 €' },
  { concepto: 'Muebles y equipamiento', imp: '300 €' },
  { concepto: 'Colchón de seguridad', imp: '300 €' },
] as const;

const barras = [
  { nombre: 'Vivienda', valor: '450 €', ancho: 'w-[75%]', color: 'bg-navy-600' },
  { nombre: 'Alimentación', valor: '268 €', ancho: 'w-[45%]', color: 'bg-mint-500' },
  { nombre: 'Suministros', valor: '83 €', ancho: 'w-[14%]', color: 'bg-navy-300' },
  { nombre: 'Ocio', valor: '95 €', ancho: 'w-[16%]', color: 'bg-mint-300' },
] as const;
---

<div
  data-plantilla-preview
  class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm"
  role="group"
  aria-label="Vista previa simulada de la plantilla Controla tu dinero en 30 días, con datos de ejemplo."
>
  <!-- Barra de ventana -->
  <div class="flex items-center justify-between gap-2 border-b border-slate-100 bg-slate-50 px-4 py-2.5">
    <div class="flex items-center gap-1.5">
      <span class="h-2.5 w-2.5 rounded-full bg-slate-300"></span>
      <span class="h-2.5 w-2.5 rounded-full bg-slate-300"></span>
      <span class="h-2.5 w-2.5 rounded-full bg-slate-300"></span>
      <span class="ml-3 hidden text-xs font-medium text-slate-400 sm:inline">Controla tu dinero en 30 días — vista previa</span>
    </div>
    <span class="rounded-full bg-mint-100 px-2.5 py-0.5 text-[11px] font-semibold text-mint-800">Vista previa</span>
  </div>

  <!-- Pestañas simuladas -->
  <div class="flex gap-1 overflow-x-auto border-b border-slate-200 bg-slate-50/60 px-3 pt-2" role="tablist" aria-label="Hojas de la plantilla (simuladas)">
    {
      tabs.map((tab, i) => (
        <button
          type="button"
          role="tab"
          data-preview-tab={tab.id}
          aria-selected={i === 0 ? 'true' : 'false'}
          aria-controls={`panel-${tab.id}`}
          class:list={[
            'shrink-0 rounded-t-lg border border-b-0 px-3.5 py-2 text-xs font-semibold transition-colors',
            i === 0
              ? 'border-slate-200 bg-white text-navy-900'
              : 'border-transparent bg-transparent text-slate-500 hover:bg-white/70 hover:text-navy-800',
          ]}
        >
          {tab.label}
        </button>
      ))
    }
  </div>

  <!-- Panel: Dashboard -->
  <div id="panel-dashboard" data-preview-panel="dashboard" role="tabpanel" class="p-4 sm:p-5" aria-hidden="false">
    <div class="grid gap-3 sm:grid-cols-4">
      <div class="rounded-xl bg-navy-50 p-3">
        <p class="text-[11px] font-medium uppercase tracking-wide text-navy-500">Ingresos</p>
        <p class="mt-1 text-lg font-bold text-navy-900">1.400 €</p>
      </div>
      <div class="rounded-xl bg-slate-50 p-3">
        <p class="text-[11px] font-medium uppercase tracking-wide text-slate-500">Gastos</p>
        <p class="mt-1 text-lg font-bold text-navy-900">860 €</p>
      </div>
      <div class="rounded-xl bg-mint-100 p-3">
        <p class="text-[11px] font-medium uppercase tracking-wide text-mint-700">Disponible</p>
        <p class="mt-1 text-lg font-bold text-mint-800">540 €</p>
      </div>
      <div class="rounded-xl bg-slate-50 p-3">
        <p class="text-[11px] font-medium uppercase tracking-wide text-slate-500">% disponible</p>
        <p class="mt-1 text-lg font-bold text-navy-900">38,6 %</p>
      </div>
    </div>
    <div class="mt-4 grid gap-4 sm:grid-cols-3">
      <div class="sm:col-span-2">
        <p class="text-xs font-semibold text-slate-500">Gasto por categoría · Abril (ejemplo)</p>
        <div class="mt-2 space-y-2">
          {
            barras.map((b) => (
              <div class="flex items-center gap-3">
                <span class="w-24 shrink-0 text-xs text-slate-500">{b.nombre}</span>
                <div class="h-2.5 flex-1 overflow-hidden rounded-full bg-slate-100">
                  <div class:list={['h-full rounded-full', b.color, b.ancho]} />
                </div>
                <span class="w-12 shrink-0 text-right text-xs font-semibold text-navy-900">{b.valor}</span>
              </div>
            ))
          }
        </div>
      </div>
      <div class="rounded-xl border border-slate-100 bg-slate-50/60 p-3">
        <p class="text-xs font-semibold text-slate-500">Resumen</p>
        <p class="mt-2 text-xs text-slate-600">Mayor gasto: <strong class="text-navy-900">Vivienda</strong></p>
        <p class="mt-1 text-xs text-slate-600">Estado: <span class="rounded-full bg-mint-100 px-2 py-0.5 text-[11px] font-semibold text-mint-800">Saldo positivo</span></p>
      </div>
    </div>
  </div>

  <!-- Panel: Gastos -->
  <div id="panel-gastos" data-preview-panel="gastos" role="tabpanel" class="hidden p-4 sm:p-5" aria-hidden="true">
    <table class="w-full text-xs">
      <thead>
        <tr class="border-b-2 border-slate-200 text-left text-slate-500">
          <th class="py-1.5 pr-2 font-semibold">Fecha</th>
          <th class="py-1.5 pr-2 font-semibold">Categoría</th>
          <th class="hidden py-1.5 pr-2 font-semibold sm:table-cell">Descripción</th>
          <th class="py-1.5 text-right font-semibold">Importe</th>
        </tr>
      </thead>
      <tbody>
        {
          gastos.map((g) => (
            <tr class="border-b border-slate-100 text-slate-600">
              <td class="py-1.5 pr-2">{g.fecha}</td>
              <td class="py-1.5 pr-2">{g.cat}</td>
              <td class="hidden py-1.5 pr-2 sm:table-cell">{g.desc}</td>
              <td class="py-1.5 text-right font-semibold text-navy-900">{g.imp}</td>
            </tr>
          ))
        }
        <tr class="text-slate-700">
          <td colspan="2" class="py-2 font-bold text-navy-900">Total del mes</td>
          <td class="hidden sm:table-cell"></td>
          <td class="py-2 text-right font-bold text-navy-900">860 €</td>
        </tr>
      </tbody>
    </table>
    <p class="mt-2 text-[11px] text-slate-400">El registro alimenta automáticamente el dashboard y el presupuesto.</p>
  </div>

  <!-- Panel: Presupuesto -->
  <div id="panel-presupuesto" data-preview-panel="presupuesto" role="tabpanel" class="hidden p-4 sm:p-5" aria-hidden="true">
    <table class="w-full text-xs">
      <thead>
        <tr class="border-b-2 border-slate-200 text-left text-slate-500">
          <th class="py-1.5 pr-2 font-semibold">Categoría</th>
          <th class="py-1.5 pr-2 text-right font-semibold">Previsto</th>
          <th class="py-1.5 pr-2 text-right font-semibold">Real</th>
          <th class="hidden py-1.5 pr-2 text-right font-semibold sm:table-cell">Diferencia</th>
          <th class="py-1.5 text-right font-semibold">Estado</th>
        </tr>
      </thead>
      <tbody>
        {
          presupuesto.map((p) => (
            <tr class="border-b border-slate-100 text-slate-600">
              <td class="py-1.5 pr-2">{p.cat}</td>
              <td class="py-1.5 pr-2 text-right">{p.previsto}</td>
              <td class="py-1.5 pr-2 text-right font-semibold text-navy-900">{p.real}</td>
              <td class="hidden py-1.5 pr-2 text-right sm:table-cell">{p.dif}</td>
              <td class="py-1.5 text-right">
                <span
                  class:list={[
                    'rounded-full px-2 py-0.5 text-[11px] font-semibold',
                    p.estado === 'Bien' ? 'bg-mint-100 text-mint-800' : 'bg-amber-100 text-amber-800',
                  ]}
                >
                  {p.estado}
                </span>
              </td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>

  <!-- Panel: Objetivos -->
  <div id="panel-objetivos" data-preview-panel="objetivos" role="tabpanel" class="hidden p-4 sm:p-5" aria-hidden="true">
    <div class="space-y-3">
      {
        objetivos.map((o) => (
          <div>
            <div class="flex items-baseline justify-between gap-2">
              <p class="text-xs font-semibold text-navy-900">{o.nombre}</p>
              <p class="text-[11px] text-slate-500">
                {o.ahorrado} de {o.objetivo}
              </p>
            </div>
            <div class="mt-1 h-2.5 w-full overflow-hidden rounded-full bg-slate-100">
              <div class:list={['h-full rounded-full bg-mint-400', o.pct]} />
            </div>
          </div>
        ))
      }
    </div>
    <p class="mt-3 text-[11px] text-slate-400">Cada objetivo calcula el ahorro mensual necesario según su fecha.</p>
  </div>

  <!-- Panel: Mudanza -->
  <div id="panel-mudanza" data-preview-panel="mudanza" role="tabpanel" class="hidden p-4 sm:p-5" aria-hidden="true">
    <div class="space-y-1.5">
      {
        mudanza.map((m) => (
          <div class="flex items-center justify-between border-b border-slate-100 py-1.5 text-xs text-slate-600">
            <span>{m.concepto}</span>
            <span class="font-semibold text-navy-900">{m.imp}</span>
          </div>
        ))
      }
      <div class="flex items-center justify-between py-2 text-sm">
        <span class="font-bold text-navy-900">Coste total de entrada</span>
        <span class="font-bold text-navy-900">2.150 €</span>
      </div>
    </div>
    <p class="mt-2 text-[11px] text-slate-400">Cifras de ejemplo: el simulador trabaja con tus importes reales.</p>
  </div>

  <!-- Panel: Alquiler -->
  <div id="panel-alquiler" data-preview-panel="alquiler" role="tabpanel" class="hidden p-4 sm:p-5" aria-hidden="true">
    <div class="grid gap-4 sm:grid-cols-2">
      <div class="rounded-xl border border-slate-100 bg-slate-50/60 p-3">
        <p class="text-xs font-semibold text-slate-500">Datos (ejemplo)</p>
        <div class="mt-2 space-y-1.5 text-xs text-slate-600">
          <p class="flex justify-between"><span>Ingresos netos</span><span class="font-semibold text-navy-900">1.400 €</span></p>
          <p class="flex justify-between"><span>Alquiler estimado</span><span class="font-semibold text-navy-900">470 €</span></p>
          <p class="flex justify-between"><span>Resto de gastos</span><span class="font-semibold text-navy-900">620 €</span></p>
        </div>
      </div>
      <div class="rounded-xl bg-navy-50 p-3">
        <p class="text-xs font-semibold text-navy-500">Resultado</p>
        <div class="mt-2 space-y-1.5 text-xs text-navy-800">
          <p class="flex justify-between"><span>% del sueldo en alquiler</span><span class="font-bold">33,6 %</span></p>
          <p class="flex justify-between"><span>Dinero restante</span><span class="font-bold">310 €</span></p>
          <p class="flex justify-between"><span>Coste anual del alquiler</span><span class="font-bold">5.640 €</span></p>
        </div>
      </div>
    </div>
  </div>

  <!-- Nota de preview -->
  <p class="border-t border-slate-100 bg-slate-50 px-4 py-2.5 text-center text-[11px] text-slate-500">
    Vista previa con datos de ejemplo. El archivo descargable es un Excel editable que funciona con tus datos.
  </p>
</div>

<script>
  document.querySelectorAll<HTMLElement>('[data-plantilla-preview]').forEach((preview) => {
    const tabs = preview.querySelectorAll<HTMLButtonElement>('[data-preview-tab]');
    const panels = preview.querySelectorAll<HTMLElement>('[data-preview-panel]');
    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const target = tab.dataset.previewTab;
        tabs.forEach((t) => {
          const active = t === tab;
          t.setAttribute('aria-selected', String(active));
          t.classList.toggle('border-slate-200', active);
          t.classList.toggle('bg-white', active);
          t.classList.toggle('text-navy-900', active);
          t.classList.toggle('border-transparent', !active);
          t.classList.toggle('bg-transparent', !active);
          t.classList.toggle('text-slate-500', !active);
        });
        panels.forEach((panel) => {
          const show = panel.dataset.previewPanel === target;
          panel.classList.toggle('hidden', !show);
          panel.setAttribute('aria-hidden', String(!show));
        });
      });
    });
  });
</script>
