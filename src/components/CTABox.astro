---
interface Props {
  title: string;
  description: string;
  buttonLabel: string;
  buttonHref: string;
  secondaryLabel?: string;
  secondaryHref?: string;
  /** Añade el atributo download al botón secundario (p. ej. para la demo .xlsx). */
  secondaryDownload?: boolean;
  /** Texto pequeño bajo los botones (p. ej. aviso de la demo). */
  note?: string;
}

const { title, description, buttonLabel, buttonHref, secondaryLabel, secondaryHref, secondaryDownload, note } =
  Astro.props;
---

<div class="rounded-2xl bg-navy-900 px-6 py-8 text-center sm:px-10">
  <h2 class="text-xl font-bold text-white sm:text-2xl">{title}</h2>
  <p class="mx-auto mt-3 max-w-xl text-sm leading-relaxed text-navy-100 sm:text-base">{description}</p>
  <div class="mt-6 flex flex-col items-center justify-center gap-3 sm:flex-row">
    <a
      href={buttonHref}
      class="w-full rounded-lg bg-mint-400 px-6 py-3 text-sm font-semibold text-navy-950 transition-colors hover:bg-mint-300 sm:w-auto"
    >
      {buttonLabel}
    </a>
    {
      secondaryLabel && secondaryHref && (
        <a
          href={secondaryHref}
          download={secondaryDownload}
          class="w-full rounded-lg border border-navy-500 px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-navy-800 sm:w-auto"
        >
          {secondaryLabel}
        </a>
      )
    }
  </div>
  {note && <p class="mt-3 text-xs text-navy-300">{note}</p>}
</div>
