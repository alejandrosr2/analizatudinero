---
import { SITE, buildTitle, canonicalUrl } from '@utils/seo';

interface Props {
  title: string;
  description: string;
  /** Tipo Open Graph: 'website' o 'article' */
  type?: 'website' | 'article';
  /** Ruta de la imagen OG (absoluta o relativa al sitio) */
  image?: string;
  /** Objetos JSON-LD a inyectar en la página */
  jsonLd?: object[];
  /** Indica a los buscadores que no indexen la página */
  noindex?: boolean;
}

const { title, description, type = 'website', image, jsonLd = [], noindex = false } = Astro.props;

const fullTitle = buildTitle(title);
const canonical = canonicalUrl(Astro.url.pathname);
const ogImage = image ? new URL(image, SITE.url).href : `${SITE.url}/og-default.svg`;
---

<title>{fullTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
{noindex && <meta name="robots" content="noindex, follow" />}

<!-- Open Graph -->
<meta property="og:type" content={type} />
<meta property="og:site_name" content={SITE.name} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImage} />
<meta property="og:locale" content={SITE.locale} />

<!-- Twitter Cards -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />

{jsonLd.map((schema) => <script type="application/ld+json" set:html={JSON.stringify(schema)} />)}
