---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import DisclaimerBox from '@components/DisclaimerBox.astro';
import { breadcrumbsJsonLd } from '@utils/seo';

const jsonLd = [
  breadcrumbsJsonLd([
    { label: 'Inicio', href: '/' },
    { label: 'Contacto', href: '/contacto' },
  ]),
];
---

<BaseLayout
  title="Contacto"
  description="Contacta con el equipo de Analiza Tu Dinero para colaboraciones, sugerencias, avisos de errores o patrocinios. No respondemos consultas financieras personalizadas."
  jsonLd={jsonLd}
>
  <div class="mx-auto max-w-3xl px-4 py-10 sm:px-6">
    <Breadcrumbs items={[{ label: 'Contacto' }]} />

    <h1 class="mt-6 text-3xl font-extrabold tracking-tight text-navy-900 sm:text-4xl">Contacto</h1>
    <p class="mt-4 text-lg leading-relaxed text-slate-600">
      ¿Has encontrado un error, tienes una sugerencia o quieres proponer una colaboración?
      Escríbenos y te leeremos con atención.
    </p>

    <div class="mt-6">
      <DisclaimerBox text="No respondemos consultas financieras personalizadas. Si necesitas asesoramiento sobre tu situación concreta, acude a un profesional regulado." />
    </div>

    <!-- Formulario visual: pendiente de conectar con un servicio de formularios externo -->
    <form id="contact-form" class="mt-8 rounded-2xl border border-slate-200 bg-white p-6 sm:p-8" novalidate>
      <div class="grid gap-5 sm:grid-cols-2">
        <div>
          <label for="nombre" class="form-label">Nombre</label>
          <input type="text" id="nombre" name="nombre" autocomplete="name" placeholder="Tu nombre" class="form-input" />
        </div>
        <div>
          <label for="email" class="form-label">Correo electrónico</label>
          <input type="email" id="email" name="email" autocomplete="email" placeholder="tu@email.com" class="form-input" />
        </div>
        <div class="sm:col-span-2">
          <label for="motivo" class="form-label">Motivo</label>
          <select id="motivo" name="motivo" class="form-input">
            <option value="sugerencia">Sugerencia o idea</option>
            <option value="error">He encontrado un error</option>
            <option value="colaboracion">Colaboración o patrocinio</option>
            <option value="otro">Otro</option>
          </select>
        </div>
        <div class="sm:col-span-2">
          <label for="mensaje" class="form-label">Mensaje</label>
          <textarea id="mensaje" name="mensaje" rows="5" placeholder="Cuéntanos en qué podemos ayudarte" class="form-input"></textarea>
        </div>
      </div>
      <button
        type="submit"
        class="mt-6 w-full rounded-lg bg-navy-900 px-6 py-3 text-base font-semibold text-white transition-colors hover:bg-navy-700 sm:w-auto"
      >
        Enviar mensaje
      </button>
      <p id="contact-ok" class="mt-4 hidden rounded-lg bg-mint-100 px-4 py-3 text-sm text-mint-800" role="status">
        El formulario aún no está activo y no se ha enviado ni guardado ningún dato. Mientras lo
        conectamos, puedes escribirnos directamente a
        <a href="mailto:contacto@analizatudinero.com" class="font-semibold underline">contacto@analizatudinero.com</a>.
      </p>
    </form>

    <p class="mt-6 text-slate-600">
      También puedes escribirnos directamente a
      <a href="mailto:contacto@analizatudinero.com" class="font-semibold text-navy-700 underline hover:text-navy-900">
        contacto@analizatudinero.com
      </a>
    </p>

    <!-- Colaboraciones -->
    <section id="colaboraciones" class="mt-12 rounded-2xl border border-slate-200 bg-slate-50 p-6 sm:p-8">
      <h2 class="text-xl font-bold text-navy-900">Colaboraciones</h2>
      <p class="mt-3 leading-relaxed text-slate-600">
        Estamos abiertos a colaboraciones con herramientas, proyectos educativos y marcas alineadas
        con la organización financiera personal. No aceptamos promociones de inversión de alto
        riesgo, trading, criptoactivos ni mensajes engañosos.
      </p>
      <p class="mt-3 text-sm text-slate-500">
        Si tu propuesta encaja, escríbenos indicando "Colaboración" en el asunto.
      </p>
    </section>
  </div>
</BaseLayout>

<script>
  // El formulario aún no está conectado a ningún servicio: no envía ni guarda datos.
  const form = document.getElementById('contact-form') as HTMLFormElement;
  form.addEventListener('submit', (event) => {
    event.preventDefault();
    document.getElementById('contact-ok')?.classList.remove('hidden');
    form.reset();
  });
</script>
