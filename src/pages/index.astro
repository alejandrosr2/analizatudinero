---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import Card from '@components/Card.astro';
import CTABox from '@components/CTABox.astro';
import DownloadBox from '@components/DownloadBox.astro';
import TemplateMockup from '@components/TemplateMockup.astro';
import { websiteJsonLd, organizationJsonLd } from '@utils/seo';

const beneficios = [
  {
    titulo: 'Controla tus gastos',
    texto: 'Pon orden en lo que entra y lo que sale cada mes con herramientas sencillas, sin hojas de cálculo imposibles.',
    icon: 'wallet',
  },
  {
    titulo: 'Compara decisiones importantes',
    texto: 'Mudarte, independizarte, vivir solo o compartir piso: pon números a cada escenario antes de decidir.',
    icon: 'chart',
  },
  {
    titulo: 'Usa plantillas sencillas',
    texto: 'Plantillas pensadas para empezar en minutos, no para pelearte con fórmulas ni configuraciones.',
    icon: 'template',
  },
  {
    titulo: 'Aprende sin tecnicismos',
    texto: 'Guías claras en lenguaje normal, con ejemplos prácticos y sin jerga financiera innecesaria.',
    icon: 'guide',
  },
] as const;

const calculadoras = [
  {
    titulo: 'Presupuesto mensual',
    texto: 'Suma tus gastos, compáralos con tus ingresos y descubre cuánto te queda libre cada mes.',
    href: '/calculadoras/presupuesto-mensual',
  },
  {
    titulo: 'Alquiler máximo',
    texto: 'Calcula qué alquiler encaja con tus ingresos según el porcentaje que tú decidas destinar a vivienda.',
    href: '/calculadoras/alquiler-maximo',
  },
  {
    titulo: 'Fondo de emergencia',
    texto: 'Estima cuánto colchón necesitas para imprevistos y cuánto te falta para conseguirlo.',
    href: '/calculadoras/fondo-emergencia',
  },
] as const;

const guias = [
  {
    titulo: 'Cómo organizar tu primer sueldo sin complicarte',
    texto: 'Un método simple para repartir tu primera nómina entre gastos fijos, ahorro y ocio.',
    href: '/guias/como-organizar-tu-primer-sueldo',
  },
  {
    titulo: 'Cómo crear un presupuesto mensual realista',
    texto: 'Las categorías mínimas, cómo revisarlo cada mes y los errores que hacen que lo abandones.',
    href: '/guias/como-crear-un-presupuesto-mensual',
  },
  {
    titulo: 'Cómo saber si puedes independizarte',
    texto: 'Todos los gastos que deberías calcular antes de firmar un alquiler: fianza, suministros, colchón y más.',
    href: '/guias/como-saber-si-puedes-independizarte',
  },
] as const;

const jsonLd = [websiteJsonLd(), organizationJsonLd()];
---

<BaseLayout
  title="Analiza tu dinero antes de tomar decisiones importantes"
  description="Calculadoras, plantillas y guías para entender tus gastos, comparar escenarios y organizar tu economía personal sin complicarte. Educación financiera práctica en español."
  jsonLd={jsonLd}
>
  <Hero
    title="Analiza tu dinero antes de tomar decisiones importantes"
    subtitle="Calculadoras, plantillas y guías para entender tus gastos, comparar escenarios y organizar tu economía personal sin complicarte."
    primaryLabel="Empezar a analizar mi dinero"
    primaryHref="/calculadoras"
    secondaryLabel="Ver plantillas"
    secondaryHref="/plantillas"
  />

  <!-- Qué puedes hacer aquí -->
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
    <h2 class="text-center text-2xl font-bold text-navy-900 sm:text-3xl">Qué puedes hacer aquí</h2>
    <p class="mx-auto mt-3 max-w-2xl text-center text-slate-600">
      Analiza tus gastos, compara escenarios y toma mejores decisiones con tu dinero. Sin humo y sin
      tecnicismos.
    </p>
    <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        beneficios.map((b) => (
          <Card title={b.titulo} description={b.texto} icon={b.icon} />
        ))
      }
    </div>
  </section>

  <!-- Calculadoras destacadas -->
  <section class="border-y border-slate-100 bg-slate-50/60">
    <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
      <div class="flex flex-col items-start justify-between gap-3 sm:flex-row sm:items-end">
        <div>
          <h2 class="text-2xl font-bold text-navy-900 sm:text-3xl">Calculadoras destacadas</h2>
          <p class="mt-2 max-w-xl text-slate-600">
            Funcionan en tu navegador y no guardan ningún dato. Introduce tus números y compara.
          </p>
        </div>
        <a href="/calculadoras" class="text-sm font-semibold text-navy-700 hover:text-navy-900 hover:underline">
          Ver todas las calculadoras →
        </a>
      </div>
      <div class="mt-8 grid gap-6 md:grid-cols-3">
        {
          calculadoras.map((c) => (
            <Card title={c.titulo} description={c.texto} href={c.href} linkLabel="Usar calculadora" icon="calculator" badge="Calculadora" />
          ))
        }
      </div>
    </div>
  </section>

  <!-- Calculadoras para decisiones importantes -->
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
    <h2 class="text-2xl font-bold text-navy-900 sm:text-3xl">Calculadoras para decisiones importantes</h2>
    <p class="mt-2 max-w-xl text-slate-600">
      Simuladores educativos para las preguntas grandes. Comparan escenarios con tus supuestos: no
      recomiendan ninguna opción.
    </p>
    <div class="mt-8 grid gap-6 md:grid-cols-3">
      <Card
        title="¿Comprar o alquilar?"
        description="Compara el desembolso acumulado de cada opción a 5, 10, 20 y 30 años con tus propios supuestos."
        href="/calculadoras/comprar-o-alquilar"
        linkLabel="Comparar escenarios"
        icon="home"
        badge="Calculadora"
      />
      <Card
        title="Inflación y poder adquisitivo"
        description="Cuánto poder de compra pierde tu dinero con el tiempo y cuánto tendría que subir tu sueldo para compensarlo."
        href="/calculadoras/inflacion-poder-adquisitivo"
        linkLabel="Calcular mi caso"
        icon="chart"
        badge="Calculadora"
      />
      <Card
        title="Interés compuesto"
        description="Entiende el crecimiento compuesto con una simulación año a año. Educativo, sin recomendaciones de inversión."
        href="/calculadoras/interes-compuesto"
        linkLabel="Simular crecimiento"
        icon="calculator"
        badge="Calculadora"
      />
    </div>
  </section>

  <!-- Guías para empezar -->
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
    <div class="flex flex-col items-start justify-between gap-3 sm:flex-row sm:items-end">
      <div>
        <h2 class="text-2xl font-bold text-navy-900 sm:text-3xl">Guías para empezar</h2>
        <p class="mt-2 max-w-xl text-slate-600">
          Explicaciones claras y paso a paso sobre las decisiones de dinero más habituales.
        </p>
      </div>
      <a href="/guias" class="text-sm font-semibold text-navy-700 hover:text-navy-900 hover:underline">
        Ver todas las guías →
      </a>
    </div>
    <div class="mt-8 grid gap-6 md:grid-cols-3">
      {
        guias.map((g) => (
          <Card title={g.titulo} description={g.texto} href={g.href} linkLabel="Leer guía" icon="guide" badge="Guía" />
        ))
      }
    </div>
  </section>

  <!-- Plantillas -->
  <section class="border-y border-slate-100 bg-slate-50/60">
    <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
      <div class="grid items-center gap-10 lg:grid-cols-2">
        <div>
          <h2 class="text-2xl font-bold text-navy-900 sm:text-3xl">
            Descarga gratis la plantilla Controla tu dinero en 30 días
          </h2>
          <p class="mt-4 leading-relaxed text-slate-600">
            Un archivo Excel editable para organizar ingresos, gastos, presupuesto mensual,
            objetivos de ahorro y simuladores prácticos. Descarga directa,
            <strong class="font-semibold text-navy-900">sin registro y sin email</strong>.
          </p>
          <ul class="mt-5 space-y-2.5 text-slate-600">
            <li class="flex items-start gap-2.5">
              <svg class="mt-1 h-4 w-4 shrink-0 text-mint-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              Diez módulos conectados en un único archivo editable.
            </li>
            <li class="flex items-start gap-2.5">
              <svg class="mt-1 h-4 w-4 shrink-0 text-mint-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              Pensada para situaciones reales: primer sueldo, mudanza, independizarse.
            </li>
            <li class="flex items-start gap-2.5">
              <svg class="mt-1 h-4 w-4 shrink-0 text-mint-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              Sin promesas de ahorro garantizado: solo orden y claridad.
            </li>
          </ul>
          <div class="mt-7 flex flex-col gap-3 sm:flex-row">
            <a
              href="/descargas/plantilla-controla-tu-dinero.xlsx"
              download
              class="rounded-lg bg-navy-900 px-6 py-3 text-center text-sm font-semibold text-white transition-colors hover:bg-navy-700"
            >
              Descargar plantilla gratis
            </a>
            <a
              href="/plantillas/controla-tu-dinero"
              class="rounded-lg border border-slate-300 bg-white px-6 py-3 text-center text-sm font-semibold text-navy-900 transition-colors hover:border-navy-300 hover:bg-navy-50"
            >
              Ver qué incluye
            </a>
          </div>
          <p class="mt-3 text-xs text-slate-400">Archivo .xlsx · Editable · Sin registro · Datos de ejemplo incluidos</p>
        </div>
        <TemplateMockup />
      </div>
    </div>
  </section>

  <!-- Bloque de confianza -->
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
    <div class="rounded-2xl border border-slate-200 bg-white p-8 sm:p-10">
      <h2 class="text-2xl font-bold text-navy-900 sm:text-3xl">Sin humo. Solo herramientas.</h2>
      <div class="mt-6 grid gap-6 sm:grid-cols-3">
        <div>
          <p class="font-semibold text-navy-900">No vendemos inversión</p>
          <p class="mt-2 text-sm leading-relaxed text-slate-600">
            Aquí no encontrarás recomendaciones de bolsa, criptomonedas, brókers ni productos
            financieros. No es nuestro terreno.
          </p>
        </div>
        <div>
          <p class="font-semibold text-navy-900">No damos consejos personalizados</p>
          <p class="mt-2 text-sm leading-relaxed text-slate-600">
            Publicamos herramientas y metodologías generales. Las decisiones sobre tu dinero son
            tuyas, con tus datos y tu contexto.
          </p>
        </div>
        <div>
          <p class="font-semibold text-navy-900">No prometemos resultados</p>
          <p class="mt-2 text-sm leading-relaxed text-slate-600">
            Nada de “ahorra X garantizado” ni fórmulas mágicas. Organizar el dinero es un hábito,
            no un truco.
          </p>
        </div>
      </div>
      <p class="mt-8 rounded-xl bg-slate-50 px-4 py-3 text-sm text-slate-500">
        Contenido educativo, no asesoramiento financiero. Más información en el
        <a href="/aviso-legal" class="font-medium text-navy-700 underline hover:text-navy-900">aviso legal</a>.
      </p>
    </div>
  </section>

  <!-- Descarga de la plantilla -->
  <section class="mx-auto max-w-6xl px-4 pb-16 sm:px-6">
    <DownloadBox showDetailsLink />
  </section>

  <!-- CTA final -->
  <section class="mx-auto max-w-6xl px-4 pb-20 sm:px-6">
    <CTABox
      title="Empieza por ponerle números a tu mes"
      description="La calculadora de presupuesto mensual es el mejor punto de partida: cinco minutos para saber cuánto gastas y cuánto te queda."
      buttonLabel="Calcular mi presupuesto"
      buttonHref="/calculadoras/presupuesto-mensual"
      secondaryLabel="Ver todas las calculadoras"
      secondaryHref="/calculadoras"
    />
  </section>
</BaseLayout>
