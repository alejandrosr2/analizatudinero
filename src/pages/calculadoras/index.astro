---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import Card from '@components/Card.astro';
import DisclaimerBox from '@components/DisclaimerBox.astro';
import CTABox from '@components/CTABox.astro';
import { breadcrumbsJsonLd } from '@utils/seo';

const calculadoras = [
  {
    titulo: 'Calculadora de presupuesto mensual',
    texto: 'Introduce tus ingresos y gastos por categorías y descubre cuánto dinero te queda libre cada mes y qué porcentaje gastas.',
    href: '/calculadoras/presupuesto-mensual',
  },
  {
    titulo: 'Calculadora de alquiler máximo',
    texto: 'Calcula el alquiler máximo orientativo según tus ingresos netos y el porcentaje que quieras destinar a vivienda.',
    href: '/calculadoras/alquiler-maximo',
  },
  {
    titulo: 'Calculadora de fondo de emergencia',
    texto: 'Estima cuánto colchón necesitas para cubrir varios meses de gastos esenciales y cuánto te falta por ahorrar.',
    href: '/calculadoras/fondo-emergencia',
  },
  {
    titulo: 'Calculadora de coste de mudanza',
    texto: 'Suma fianza, primer mes, agencia, transporte, muebles y colchón de seguridad para saber cuánto cuesta mudarte.',
    href: '/calculadoras/coste-mudanza',
  },
  {
    titulo: 'Vivir solo vs compartir piso',
    texto: 'Compara cuánto te costaría cada opción al mes y al año, y qué porcentaje de tu sueldo se lleva cada escenario.',
    href: '/calculadoras/vivir-solo-compartir',
  },
  {
    titulo: 'Comprar o alquilar',
    texto: 'Compara el desembolso acumulado de comprar una vivienda frente a vivir de alquiler a 5, 10, 20 y 30 años, con tus supuestos.',
    href: '/calculadoras/comprar-o-alquilar',
  },
  {
    titulo: 'Inflación y poder adquisitivo',
    texto: 'Descubre cuánto poder de compra pierde tu dinero con el tiempo y cuánto tendría que subir tu sueldo para compensarlo.',
    href: '/calculadoras/inflacion-poder-adquisitivo',
  },
  {
    titulo: 'Interés compuesto',
    texto: 'Simulador educativo del crecimiento compuesto: aportaciones, tasa hipotética y evolución año a año. Sin recomendaciones de inversión.',
    href: '/calculadoras/interes-compuesto',
  },
] as const;

const jsonLd = [
  breadcrumbsJsonLd([
    { label: 'Inicio', href: '/' },
    { label: 'Calculadoras', href: '/calculadoras' },
  ]),
];
---

<BaseLayout
  title="Calculadoras de economía personal gratuitas"
  description="Calculadoras gratuitas para analizar presupuesto, alquiler, mudanza, fondo de emergencia, comprar o alquilar, inflación, poder adquisitivo e interés compuesto. Funcionan en tu navegador y no guardan datos."
  jsonLd={jsonLd}
>
  <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6">
    <Breadcrumbs items={[{ label: 'Calculadoras' }]} />

    <header class="mt-6 max-w-2xl">
      <h1 class="text-3xl font-extrabold tracking-tight text-navy-900 sm:text-4xl">
        Calculadoras de economía personal
      </h1>
      <p class="mt-4 text-lg leading-relaxed text-slate-600">
        Herramientas gratuitas para poner números a tus decisiones: presupuesto, alquiler,
        emergencias, mudanzas, vivienda compartida, comprar o alquilar, inflación e interés
        compuesto. Todas funcionan en tu navegador y
        <strong class="font-semibold text-navy-900">no guardan ni envían ningún dato</strong>.
      </p>
    </header>

    <div class="mt-8">
      <DisclaimerBox text="Las calculadoras ofrecen estimaciones orientativas a partir de los datos que tú introduces. No son asesoramiento financiero ni tienen en cuenta tu situación personal completa." />
    </div>

    <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        calculadoras.map((c) => (
          <Card title={c.titulo} description={c.texto} href={c.href} linkLabel="Usar calculadora" icon="calculator" badge="Gratis" />
        ))
      }
    </div>

    <div class="mt-16">
      <CTABox
        title="¿Prefieres llevar estos cálculos mes a mes?"
        description="Las calculadoras te dan una foto puntual. La plantilla gratuita «Controla tu dinero en 30 días» convierte estos cálculos en módulos conectados que se actualizan con tus datos. Descarga directa, sin registro."
        buttonLabel="Descargar plantilla gratis"
        buttonHref="/descargas/plantilla-controla-tu-dinero.xlsx"
        buttonDownload
        secondaryLabel="Ver qué incluye"
        secondaryHref="/plantillas/controla-tu-dinero"
        note="Archivo .xlsx · Editable · Sin registro · Datos de ejemplo incluidos"
      />
    </div>
  </div>
</BaseLayout>
