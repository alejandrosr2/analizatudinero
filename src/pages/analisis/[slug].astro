---
import { getCollection, render } from 'astro:content';
import ArticleLayout from '@layouts/ArticleLayout.astro';

export async function getStaticPaths() {
  const articulos = await getCollection('analisis', ({ data }) => !data.draft);
  return articulos.map((articulo) => ({
    params: { slug: articulo.id },
    props: { articulo },
  }));
}

const { articulo } = Astro.props;
const { Content } = await render(articulo);
---

<ArticleLayout
  title={articulo.data.title}
  description={articulo.data.description}
  pubDate={articulo.data.pubDate}
  updatedDate={articulo.data.updatedDate}
  section={{ label: 'Análisis', href: '/analisis' }}
  cta={articulo.data.cta}
  disclaimer={articulo.data.disclaimer}
>
  <Content />
</ArticleLayout>
