---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import DisclaimerBox from '@components/DisclaimerBox.astro';
import DownloadBox from '@components/DownloadBox.astro';
import TemplateMockup from '@components/TemplateMockup.astro';
import { breadcrumbsJsonLd } from '@utils/seo';
import { DESCARGA, MODULOS, PRODUCTO } from '@utils/modulos';

const incluye = [
  {
    titulo: 'Todo en un archivo',
    texto: 'Nada de tres apps y cinco notas: ingresos, gastos, presupuesto, objetivos y simuladores conectados entre sí.',
  },
  {
    titulo: 'Se actualiza sola',
    texto: 'Apuntas un gasto y el dashboard, el presupuesto y los porcentajes se recalculan al instante.',
  },
  {
    titulo: 'Decisiones con números',
    texto: 'Los simuladores de alquiler, mudanza y vivienda compartida te dan la cifra antes de comprometerte.',
  },
  {
    titulo: 'Plan de 30 días',
    texto: 'No es solo una plantilla: es un recorrido guiado para que en un mes tengas el sistema funcionando.',
  },
  {
    titulo: 'Tus datos son tuyos',
    texto: 'Sin registro, sin nube obligatoria, sin macros. El archivo vive en tu ordenador o tu Drive.',
  },
  {
    titulo: 'Sin jerga financiera',
    texto: 'Celdas marcadas para escribir, el resto se calcula. Si sabes rellenar un formulario, te vale.',
  },
] as const;

const paraQuien = [
  'Quieres dejar de preguntarte a dónde se va tu dinero cada mes.',
  'Cobras tus primeros sueldos y quieres montar un sistema sencillo desde el principio.',
  'Estás valorando independizarte, mudarte o cambiar de trabajo y necesitas números, no corazonadas.',
  'Has probado apps y hojas sueltas y siempre las abandonas a las dos semanas.',
] as const;

const queNoHace = [
  'No recomienda inversiones ni productos financieros.',
  'No recomienda bancos, préstamos, hipotecas, brókers, tarjetas ni criptomonedas.',
  'No sustituye el asesoramiento financiero, fiscal o legal profesional.',
  'No guarda ni envía datos del usuario: todo queda en tu archivo.',
  'No promete resultados ni cifras de ahorro garantizadas.',
] as const;

const faq = [
  {
    q: '¿De verdad es gratis?',
    a: 'Sí. Descargas el archivo directamente, sin registro, sin email y sin pasos intermedios. La web se financiará en el futuro con publicidad o colaboraciones educativas, nunca con promociones de inversión.',
  },
  {
    q: '¿Qué descargo exactamente?',
    a: 'Un archivo de hoja de cálculo (.xlsx) editable con los 10 módulos, la guía de uso de 30 días incluida en el propio archivo y datos de ejemplo que puedes borrar para empezar con los tuyos.',
  },
  {
    q: '¿Necesito saber de Excel?',
    a: 'No. Las celdas donde escribes están marcadas en color y el resto se calcula solo. La revisión mensual te va guiando paso a paso.',
  },
  {
    q: '¿Funciona en Google Sheets y LibreOffice?',
    a: 'Sí. Es una hoja de cálculo estándar sin macros, compatible con Excel, Google Sheets y LibreOffice.',
  },
  {
    q: '¿La plantilla guarda mis datos en algún sitio?',
    a: 'No. El archivo funciona localmente en tu ordenador o en tu propia nube si tú lo subes. Esta web no recibe ni almacena nada de lo que escribas en él.',
  },
  {
    q: '¿Esto es asesoramiento financiero?',
    a: 'No. Es una herramienta educativa de organización personal. No analiza tu caso ni recomienda productos: las decisiones siguen siendo tuyas.',
  },
] as const;

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
};

const jsonLd = [
  breadcrumbsJsonLd([
    { label: 'Inicio', href: '/' },
    { label: 'Plantillas', href: '/plantillas' },
    { label: PRODUCTO.nombre, href: PRODUCTO.url },
  ]),
  faqJsonLd,
];
---

<BaseLayout
  title="Plantilla gratis para controlar tu dinero en Excel"
  description="Descarga gratis una plantilla Excel editable para organizar ingresos, gastos, presupuesto mensual, objetivos de ahorro, alquiler, mudanza y decisiones económicas cotidianas."
  jsonLd={jsonLd}
>
  <div class="mx-auto max-w-4xl px-4 py-10 sm:px-6">
    <Breadcrumbs
      items={[{ label: 'Plantillas', href: '/plantillas' }, { label: PRODUCTO.nombre }]}
    />

    <!-- Hero -->
    <header class="mt-8 text-center">
      <span class="rounded-full bg-mint-100 px-4 py-1.5 text-sm font-semibold text-mint-800">
        Gratis · Descarga directa · Sin registro
      </span>
      <h1 class="mt-5 text-3xl font-extrabold tracking-tight text-navy-900 sm:text-5xl">
        Plantilla gratis: {PRODUCTO.nombre}
      </h1>
      <p class="mx-auto mt-5 max-w-2xl text-lg leading-relaxed text-slate-600">
        Organiza ingresos, gastos, presupuesto, objetivos, alquiler, mudanza y decisiones económicas
        cotidianas desde un único archivo Excel editable.
      </p>
      <div class="mt-7 flex flex-col items-center justify-center gap-3 sm:flex-row">
        <a
          href={DESCARGA.url}
          download
          class="w-full rounded-lg bg-navy-900 px-8 py-3.5 text-base font-semibold text-white transition-colors hover:bg-navy-700 sm:w-auto"
        >
          {DESCARGA.label}
        </a>
        <a
          href="#preview"
          class="w-full rounded-lg border border-slate-300 bg-white px-8 py-3.5 text-base font-semibold text-navy-900 transition-colors hover:border-navy-300 hover:bg-navy-50 sm:w-auto"
        >
          Ver preview
        </a>
      </div>
      <p class="mt-3 text-xs text-slate-400">{DESCARGA.aviso}</p>
    </header>

    <!-- Preview -->
    <section id="preview" class="mt-14 scroll-mt-24">
      <TemplateMockup />
      <p class="mt-3 text-center text-xs text-slate-400">
        El archivo descargable incluye datos de ejemplo como estos: bórralos y empieza con los tuyos.
      </p>
    </section>

    <!-- Qué incluye -->
    <section class="mt-16">
      <h2 class="text-2xl font-bold text-navy-900 sm:text-3xl">Qué incluye</h2>
      <div class="mt-6 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {
          incluye.map((b) => (
            <div class="rounded-2xl border border-slate-200 bg-white p-5">
              <h3 class="font-bold text-navy-900">{b.titulo}</h3>
              <p class="mt-2 text-sm leading-relaxed text-slate-600">{b.texto}</p>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Módulos -->
    <section id="modulos" class="mt-16 scroll-mt-24">
      <h2 class="text-2xl font-bold text-navy-900 sm:text-3xl">Los 10 módulos incluidos</h2>
      <p class="mt-3 text-slate-600">
        Cada módulo tiene una calculadora o guía gratuita relacionada en la web, por si quieres
        probar el enfoque en línea antes de descargar el archivo.
      </p>
      <div class="mt-8 grid gap-5 sm:grid-cols-2">
        {
          MODULOS.map((modulo) => (
            <article id={modulo.id} class="flex h-full scroll-mt-24 flex-col rounded-2xl border border-slate-200 bg-white p-5">
              <h3 class="font-bold text-navy-900">{modulo.nombre}</h3>
              <p class="mt-2 flex-1 text-sm leading-relaxed text-slate-600">{modulo.problema}</p>
              <a href={modulo.relacionada.href} class="mt-4 text-sm font-medium text-navy-700 underline decoration-mint-400 decoration-2 underline-offset-2 hover:text-navy-900">
                En la web: {modulo.relacionada.label}
              </a>
            </article>
          ))
        }
      </div>
    </section>

    <!-- Para quién es -->
    <section class="mt-16">
      <h2 class="text-2xl font-bold text-navy-900 sm:text-3xl">Para quién es</h2>
      <ul class="mt-6 grid gap-3 sm:grid-cols-2">
        {
          paraQuien.map((item) => (
            <li class="flex items-start gap-2.5 text-slate-700">
              <svg class="mt-1 h-4 w-4 shrink-0 text-mint-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              {item}
            </li>
          ))
        }
      </ul>
    </section>

    <!-- Qué no hace -->
    <section class="mt-16 rounded-2xl border border-slate-200 bg-slate-50 p-6 sm:p-8">
      <h2 class="text-2xl font-bold text-navy-900 sm:text-3xl">Qué no hace la plantilla</h2>
      <ul class="mt-5 space-y-2.5">
        {
          queNoHace.map((item) => (
            <li class="flex items-start gap-2.5 text-sm leading-relaxed text-slate-600">
              <svg class="mt-0.5 h-4 w-4 shrink-0 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
              </svg>
              {item}
            </li>
          ))
        }
      </ul>
    </section>

    <!-- FAQ -->
    <section class="mt-16">
      <h2 class="text-2xl font-bold text-navy-900 sm:text-3xl">Preguntas frecuentes</h2>
      <div class="mt-6 space-y-4">
        {
          faq.map((item) => (
            <details class="group rounded-2xl border border-slate-200 bg-white p-5">
              <summary class="cursor-pointer list-none text-sm font-bold text-navy-900 sm:text-base">
                {item.q}
              </summary>
              <p class="mt-3 text-sm leading-relaxed text-slate-600">{item.a}</p>
            </details>
          ))
        }
      </div>
    </section>

    <div class="mt-12">
      <DisclaimerBox text="Esta plantilla es una herramienta educativa y orientativa. No constituye asesoramiento financiero, fiscal, legal ni de inversión. Los cálculos son estimaciones basadas en los datos introducidos por el usuario." />
    </div>

    <!-- CTA final de descarga -->
    <div class="mt-12">
      <DownloadBox
        title="Llévate la plantilla y empieza hoy"
        description="Descarga directa del archivo Excel editable, con los 10 módulos y datos de ejemplo. Sin registro, sin email y sin letra pequeña."
      />
    </div>

    <p class="mt-8 text-center text-xs text-slate-400">
      En el futuro, Analiza Tu Dinero podrá monetizarse mediante publicidad, enlaces de afiliado o
      colaboraciones con herramientas educativas y de productividad. No aceptamos promociones de
      inversión de alto riesgo, trading, criptoactivos ni mensajes engañosos.
    </p>
  </div>
</BaseLayout>
