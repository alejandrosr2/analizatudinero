---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumbs from '@components/Breadcrumbs.astro';
import DisclaimerBox from '@components/DisclaimerBox.astro';
import DownloadBox from '@components/DownloadBox.astro';
import TemplateMockup from '@components/TemplateMockup.astro';
import { breadcrumbsJsonLd } from '@utils/seo';
import { DESCARGA, MODULOS, PRODUCTO } from '@utils/modulos';

const incluye = [
  'Un único archivo de hoja de cálculo con 10 módulos conectados entre sí.',
  'Dashboard mensual que se actualiza solo con tus registros de ingresos y gastos.',
  'Simuladores de alquiler, mudanza y vivienda compartida con tus números.',
  'Objetivos de ahorro con cifra, fecha y ahorro mensual necesario.',
  'Revisión mensual guiada para cerrar cada mes en diez minutos.',
  'Compatible con Excel, Google Sheets y LibreOffice. Sin macros y sin conexión: tus datos solo viven en tu archivo.',
] as const;

const paraQuien = [
  'Quieres organizar tu dinero desde cero sin pelearte con fórmulas.',
  'Cobras tus primeros sueldos y quieres empezar con buen pie.',
  'Tienes cerca una decisión importante: independizarte, mudarte, cambiar de trabajo.',
  'Prefieres una herramienta completa antes que mil apps y notas sueltas.',
] as const;

const queNoHace = [
  'No recomienda inversiones ni productos financieros.',
  'No recomienda bancos, préstamos, hipotecas, brókers, tarjetas ni criptomonedas.',
  'No sustituye el asesoramiento financiero, fiscal o legal profesional.',
  'No guarda ni envía datos del usuario: todo queda en tu archivo.',
  'No promete resultados: organiza, no hace magia.',
] as const;

const faq = [
  {
    q: '¿De verdad es gratis y sin registro?',
    a: 'Sí. Puedes descargar la plantilla editable sin dejar tu email: el botón descarga el archivo directamente, sin pasos intermedios.',
  },
  {
    q: '¿Necesito saber de Excel?',
    a: 'No. Las celdas donde escribes están marcadas y el resto se calcula solo. Si sabes rellenar un formulario, sabes usar la plantilla.',
  },
  {
    q: '¿Funciona en Google Sheets y LibreOffice?',
    a: 'Sí. El archivo es una hoja de cálculo estándar sin macros, compatible con Excel, Google Sheets y LibreOffice.',
  },
  {
    q: '¿Por qué es gratis?',
    a: 'Porque la web es un proyecto editorial de educación financiera práctica. En el futuro podrá monetizarse con publicidad o colaboraciones educativas, nunca con promociones de inversión.',
  },
] as const;

const jsonLd = [
  breadcrumbsJsonLd([
    { label: 'Inicio', href: '/' },
    { label: 'Plantillas', href: '/plantillas' },
  ]),
];
---

<BaseLayout
  title="Plantilla gratis Controla tu dinero en 30 días"
  description="Descarga gratis la plantilla Excel editable Controla tu dinero en 30 días: presupuesto, gastos, objetivos de ahorro, alquiler y mudanza en un único archivo. Sin registro y sin email."
  jsonLd={jsonLd}
>
  <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6">
    <Breadcrumbs items={[{ label: 'Plantillas' }]} />

    <!-- Hero -->
    <header class="mt-8 text-center">
      <span class="rounded-full bg-mint-100 px-4 py-1.5 text-sm font-semibold text-mint-800">
        Plantilla gratis · Descarga directa · Sin email
      </span>
      <h1 class="mx-auto mt-5 max-w-3xl text-3xl font-extrabold tracking-tight text-navy-900 sm:text-5xl">
        Plantilla gratis {PRODUCTO.nombre}
      </h1>
      <p class="mx-auto mt-5 max-w-2xl text-lg leading-relaxed text-slate-600">
        Organiza ingresos, gastos, presupuesto, objetivos, alquiler, mudanza y decisiones económicas
        cotidianas desde un único archivo Excel editable.
      </p>
      <p class="mx-auto mt-3 max-w-2xl text-sm leading-relaxed text-slate-500">
        Puedes descargar la plantilla editable sin dejar tu email. Incluye datos de ejemplo para que
        puedas ver cómo funciona y adaptarla a tu situación.
      </p>
      <div class="mt-7 flex flex-col items-center justify-center gap-3 sm:flex-row">
        <a
          href={DESCARGA.url}
          download
          class="w-full rounded-lg bg-navy-900 px-7 py-3.5 text-base font-semibold text-white transition-colors hover:bg-navy-700 sm:w-auto"
        >
          {DESCARGA.label}
        </a>
        <a
          href={PRODUCTO.url}
          class="w-full rounded-lg border border-slate-300 bg-white px-7 py-3.5 text-base font-semibold text-navy-900 transition-colors hover:border-navy-300 hover:bg-navy-50 sm:w-auto"
        >
          Ver qué incluye
        </a>
      </div>
      <p class="mt-3 text-xs text-slate-400">{DESCARGA.aviso}</p>
    </header>

    <!-- Preview -->
    <section id="preview" class="mt-14 scroll-mt-24">
      <h2 class="text-center text-2xl font-bold text-navy-900 sm:text-3xl">Así es por dentro</h2>
      <p class="mx-auto mt-3 max-w-2xl text-center text-slate-600">
        Recorre las pestañas de la vista previa. El archivo que descargas incluye estos módulos en
        formato Excel editable.
      </p>
      <div class="mx-auto mt-8 max-w-4xl">
        <TemplateMockup />
      </div>
    </section>

    <!-- Qué incluye -->
    <section class="mt-16">
      <h2 class="text-2xl font-bold text-navy-900 sm:text-3xl">Qué incluye</h2>
      <ul class="mt-6 grid gap-3 sm:grid-cols-2">
        {
          incluye.map((item) => (
            <li class="flex items-start gap-2.5 rounded-xl border border-slate-200 bg-white px-4 py-3 text-sm leading-relaxed text-slate-700">
              <svg class="mt-0.5 h-4 w-4 shrink-0 text-mint-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              {item}
            </li>
          ))
        }
      </ul>
    </section>

    <!-- Módulos incluidos -->
    <section id="modulos" class="mt-16 scroll-mt-24">
      <h2 class="text-2xl font-bold text-navy-900 sm:text-3xl">Módulos incluidos</h2>
      <p class="mt-3 max-w-2xl text-slate-600">
        Diez módulos conectados en un único archivo. Cada uno tiene una calculadora o guía gratuita
        relacionada, por si quieres probar el enfoque en línea.
      </p>
      <div class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {
          MODULOS.map((modulo) => (
            <article id={modulo.id} class="flex h-full scroll-mt-24 flex-col rounded-2xl border border-slate-200 bg-white p-5">
              <h3 class="font-bold text-navy-900">{modulo.nombre}</h3>
              <p class="mt-2 flex-1 text-sm leading-relaxed text-slate-600">{modulo.problema}</p>
              <a href={modulo.relacionada.href} class="mt-4 text-sm font-medium text-navy-700 underline decoration-mint-400 decoration-2 underline-offset-2 hover:text-navy-900">
                En la web: {modulo.relacionada.label}
              </a>
            </article>
          ))
        }
      </div>
    </section>

    <!-- Para quién es -->
    <section class="mt-16">
      <h2 class="text-2xl font-bold text-navy-900 sm:text-3xl">Para quién es</h2>
      <ul class="mt-6 grid gap-3 sm:grid-cols-2">
        {
          paraQuien.map((item) => (
            <li class="flex items-start gap-2.5 text-slate-700">
              <svg class="mt-1 h-4 w-4 shrink-0 text-mint-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              {item}
            </li>
          ))
        }
      </ul>
    </section>

    <!-- Qué no hace -->
    <section class="mt-16 rounded-2xl border border-slate-200 bg-slate-50 p-6 sm:p-8">
      <h2 class="text-2xl font-bold text-navy-900 sm:text-3xl">Qué no hace (a propósito)</h2>
      <ul class="mt-5 space-y-2.5">
        {
          queNoHace.map((item) => (
            <li class="flex items-start gap-2.5 text-sm leading-relaxed text-slate-600">
              <svg class="mt-0.5 h-4 w-4 shrink-0 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
              </svg>
              {item}
            </li>
          ))
        }
      </ul>
    </section>

    <!-- FAQ -->
    <section class="mt-16">
      <h2 class="text-2xl font-bold text-navy-900 sm:text-3xl">Preguntas frecuentes</h2>
      <div class="mt-6 space-y-4">
        {
          faq.map((item) => (
            <details class="group rounded-2xl border border-slate-200 bg-white p-5">
              <summary class="cursor-pointer list-none text-sm font-bold text-navy-900 sm:text-base">
                {item.q}
              </summary>
              <p class="mt-3 text-sm leading-relaxed text-slate-600">{item.a}</p>
            </details>
          ))
        }
      </div>
    </section>

    <div class="mt-12">
      <DisclaimerBox text="Esta plantilla es una herramienta educativa y orientativa. No constituye asesoramiento financiero, fiscal, legal ni de inversión. Los cálculos son estimaciones basadas en los datos introducidos por el usuario." />
    </div>

    <!-- CTA final -->
    <div class="mt-12">
      <DownloadBox showDetailsLink />
    </div>

    <p class="mt-8 text-center text-xs text-slate-400">
      En el futuro, Analiza Tu Dinero podrá monetizarse mediante publicidad, enlaces de afiliado o
      colaboraciones con herramientas educativas y de productividad. No aceptamos promociones de
      inversión de alto riesgo, trading, criptoactivos ni mensajes engañosos.
    </p>
  </div>
</BaseLayout>
